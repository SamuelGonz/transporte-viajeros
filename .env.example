# Copia este archivo a .env.local y rellena los valores.

# ---- Credenciales de acceso ----
# Único usuario/contraseña que podrá entrar en la aplicación.
AUTH_USERNAME=
AUTH_PASSWORD=
# Clave para firmar la cookie de sesión. Genera una con:  openssl rand -hex 32
# (si la dejas vacía, se deriva de usuario+contraseña).
AUTH_SECRET=

# ---- Base de datos de progreso ----
# EN LOCAL: déjalo vacío y se usará un fichero SQLite (progreso.db).
# EN PRODUCCIÓN (Turso): crea una base de datos gratis en https://turso.tech
#   turso db create transporte-viajeros
#   turso db show transporte-viajeros --url
#   turso db tokens create transporte-viajeros
# TURSO_DATABASE_URL=libsql://tu-base-de-datos.turso.io
# TURSO_AUTH_TOKEN=tu-token
